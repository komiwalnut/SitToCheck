#pragma once

// -----------------------------------------------------------------------------
// Copy this file to `secrets.h` (same folder) and fill in your real values.
// `secrets.h` is git-ignored so your keys never get committed.
// -----------------------------------------------------------------------------

// WiFi credentials
#define WIFI_SSID "YOUR_WIFI_SSID"
#define WIFI_PASSWORD "YOUR_WIFI_PASSWORD"

// Supabase project URL, e.g. https://abcd1234.supabase.co  (no trailing slash).
#define SUPABASE_URL "https://YOUR-PROJECT-REF.supabase.co"

// Supabase service_role key (Dashboard > Project Settings > API > service_role).
// This bypasses Row Level Security, so NEVER commit this file or expose the key.
#define SUPABASE_SERVICE_KEY "YOUR-SUPABASE-SERVICE-ROLE-KEY"

// Logical device id. Must match a row in device_config / the dashboard.
#define DEVICE_ID "CHAIR_01"
